class Solution {
public:
    vector<int> runningSum(vector<int>& nums) {
        vector<int> sum(nums.size());
        
        for(int i=0; i<nums.size();i++){
            if(i==0){
                sum[0]=nums[0];
            }
            else{
                for(int j=0; j<=i;j++){
                sum[i]+=nums[j];
            }

            }
            
        }
        return sum;
     }
    
};
